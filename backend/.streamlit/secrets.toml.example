# .streamlit/secrets.toml — Railway MySQL credentials
# Copy this file to .streamlit/secrets.toml and fill in your Railway values
# DO NOT commit this file to GitHub (it is in .gitignore)

[mysql]
host     = "YOUR_RAILWAY_HOST.railway.app"
port     = 3306
database = "railway"
user     = "root"
password = "YOUR_RAILWAY_PASSWORD"
